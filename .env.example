# =============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - EJEMPLO
# =============================================================================
# Copia este archivo como .env y configura las variables según tu entorno

# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# =============================================================================
# Para desarrollo local (Codespaces/Docker)
DB_URL=jdbc:postgresql://localhost:5432/bd_citassalud
DB_USERNAME=postgres
DB_PASSWORD=root1

# Para producción (Render) - Usar la URL completa que proporciona Render
# DB_URL=postgresql://usuario:password@host:puerto/database
# DB_USERNAME=tu_usuario_render
# DB_PASSWORD=tu_password_render

# =============================================================================
# CONFIGURACIÓN JWT
# =============================================================================
JWT_SECRET=clave_secreta_super_larga_y_segura_para_jwt_tokens_2024
JWT_EXPIRATION=86400000

# =============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================================================
SERVER_PORT=8080
CONTEXT_PATH=/api

# =============================================================================
# CONFIGURACIÓN SWAGGER
# =============================================================================
# Para desarrollo local
SWAGGER_SERVER_URL=http://localhost:8080/api

# Para producción (cambiar por tu URL de Render)
# SWAGGER_SERVER_URL=https://tu-app.onrender.com/api

# =============================================================================
# CONFIGURACIÓN CORS
# =============================================================================
# Orígenes permitidos separados por coma (vacío = todos los orígenes)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# =============================================================================
# PERFIL DE SPRING BOOT
# =============================================================================
# Valores: dev, prod
SPRING_PROFILES_ACTIVE=dev

# =============================================================================
# CONFIGURACIÓN DE MONITOREO (PROMETHEUS/GRAFANA)
# =============================================================================
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=admin123
